rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function companyDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId));
    }

    function isCompanyMember(companyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/companies/$(companyId))
        && request.auth.uid in companyDoc(companyId).data.memberUids;
    }

    function incomingCompanyId() {
      return request.resource.data.companyId;
    }

    function existingCompanyId() {
      return resource.data.companyId;
    }

    match /userProfiles/{uid} {
      allow create, read, update: if isSelf(uid);
      allow delete: if false;
    }

    match /companies/{companyId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow read, update: if isCompanyMember(companyId);
      allow delete: if false;
    }

    match /{collectionName}/{documentId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAny(['companyId'])
        && isCompanyMember(incomingCompanyId());

      allow read, update, delete: if isSignedIn()
        && resource.data.keys().hasAny(['companyId'])
        && isCompanyMember(existingCompanyId());
    }
  }
}
